# ═══════════════════════════════════════════════════════════
# MindSight AI — Environment Variables Template
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── App ──
APP_ENV=development
LOG_LEVEL=INFO
FLASK_DEBUG=false
# Chave de sessão/assinatura do Flask. Obrigatória em produção.
SECRET_KEY=change-me-in-production

# ── Database ──
DATABASE_URL=sqlite:///./storage/app.db

# ── OpenAI ──
# Deixe vazio para desenvolvimento local sem chave real.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Gateway de chat: local (sem API key) | auto | openai | huggingface
# Recomendado para primeiro run: local. auto tenta HF -> OpenAI -> local.
CHAT_GATEWAY=local
# Tokens máximos da resposta do modelo (HF router usa 1024 se omitido).
CHAT_MAX_OUTPUT_TOKENS=4096

# ── Hugging Face Inference Providers (DeepSeek V4) ──
HUGGINGFACE_API_KEY=
HF_CHAT_MODEL=deepseek-ai/DeepSeek-V4-Flash
HF_BASE_URL=https://router.huggingface.co/v1

# ── LangSmith ──
# Gere a chave em https://smith.langchain.com/settings
LANGSMITH_TRACING=false
# Use LANGSMITH_API_KEY (não deixe "replace-me" se a chave real estiver em outra variável).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mindsight-ai
# LANGCHAIN_API_KEY é legado; se usar, o loader copia para LANGSMITH_API_KEY quando esta estiver vazia/placeholder.

# ── Embeddings / Vector Store ──
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE=faiss
FAISS_INDEX_PATH=./storage/faiss.index

# ── Uploads ──
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=10

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3002,http://127.0.0.1:3002,http://localhost:5000

# ── Frontend (used by Vite) ──
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_APP_NAME=MindSight AI
VITE_DEFAULT_THINKING_MODE=balanced
